# AKShare does not require a project token. Tushare is an optional auxiliary
# source; leave this empty until its adapter is used.
TUSHARE_TOKEN=

# Local-only storage. Relative paths are resolved from the repository root.
TBCAPTIAL_DATA_DIR=./var/data
TBCAPTIAL_CATALOG_PATH=./var/catalog/catalog.duckdb
TBCAPTIAL_RUNS_DIR=./var/runs
